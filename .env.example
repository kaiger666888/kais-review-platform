# Database (PostgreSQL + TimescaleDB)
POSTGRES_URL=postgresql+asyncpg://review:changeme@postgres:5432/reviewdb
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=review-platform

# Git (GitOps policy-as-code)
GIT_REPO_URL=
GIT_BRANCH=main

# Auth
API_KEY=changeme
JWT_SECRET=changeme
CAPABILITY_TOKEN_SECRET=changeme

# General
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Review timeouts
REVIEW_TIMEOUT_MINUTES=1440
AI_AUDIT_TIMEOUT_MINUTES=5

# Retention (days)
HOT_RETENTION_DAYS=30
WARM_RETENTION_DAYS=365

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
